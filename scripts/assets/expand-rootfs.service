[Unit]
Description=Expand the rootfs partition and filesystem on first boot
DefaultDependencies=no
After=local-fs.target
Before=display-manager.service graphical.target multi-user.target
ConditionPathExists=!/var/lib/bianbu-build/rootfs-expanded

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/expand-rootfs.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
